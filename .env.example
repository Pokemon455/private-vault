# ─────────────────────────────────────────────────────────────
# LangGraph Multi-Agent Chatbot — Environment Variables
# Copy this file to .env and fill in your actual keys.
# NEVER commit your real .env file to Git.
# ─────────────────────────────────────────────────────────────

# LLM — NVIDIA NIM
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=openai/gpt-oss-20b

# Vector DB — Pinecone
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX=vector

# Observability — LangSmith
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=langgraph-agent
LANGCHAIN_TRACING_V2=true

# Web Search — Apify
APIFY_API_TOKEN=your_apify_token_here

# Database — Neon PostgreSQL
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# MCP Server (Python executor)
MCP_SERVER_URL=https://your-mcp-server.onrender.com/mcp

# Agent Tuning (optional)
MAX_ITERATIONS=3
CHUNK_SIZE=1000
CHUNK_OVERLAP=100
RETRIEVER_K=5
RETRIEVER_FETCH_K=20
